{
  "problemMatcher": [
    {
      "owner": "cargo-clippy",
      "fileLocation": ["relative", "rust"],
      "pattern": [
        {
          "regexp": "^(warning|error)(\\[.+\\])?: (.+)$",
          "severity": 1,
          "message": 3
        },
        {
          "regexp": "^\\s+--> (.+):(\\d+):(\\d+)$",
          "file": 1,
          "line": 2,
          "column": 3
        }
      ]
    }
  ]
}
