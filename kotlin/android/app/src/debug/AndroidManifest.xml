<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Debug-only SampleSessionActivity: renders the session UI against mock data.
         Intentionally not a launcher activity so MainActivity stays the unambiguous
         default launch target in debug builds. Launch it explicitly with:
         adb shell am start -n dev.firezone.android/dev.firezone.android.features.session.ui.compose.SampleSessionActivity -->
    <application>
        <activity
            android:name="dev.firezone.android.features.session.ui.compose.SampleSessionActivity"
            android:exported="true"
            android:label="Firezone Sample"
            android:theme="@style/AppTheme.Base" />
    </application>
</manifest>
