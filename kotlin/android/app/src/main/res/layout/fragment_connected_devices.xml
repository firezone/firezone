<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_medium">

    <TextView
        android:id="@+id/tvConnectedDevicesTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/connected_devices_title"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingBottom="@dimen/spacing_medium" />

    <TextView
        android:id="@+id/tvConnectedDevicesEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/connected_devices_empty"
        android:textColor="@color/neutral_600"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/connectedDevicesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>
