    "next-hubspot": "^2.0.1",
    "next-sitemap": "^4.2.3",
    "postcss": "8.5.15",
    "posthog-js": "^1.373.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-fast-marquee": "^1.6.5",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
