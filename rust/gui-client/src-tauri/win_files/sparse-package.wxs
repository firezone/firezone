<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX fragment for the Firezone sparse MSIX package.

  Pulled into the main MSI via `tauri.conf.json:fragmentPaths`. Two
  components ship the sparse-MSIX payload (`firezone.msix`) and the
  custom-action helper (`register-sparse.exe`) into INSTALLDIR.

  Three deferred custom actions, sequenced from `main.wxs`:

  - `AddSparsePackage` — runs **impersonated** as the user invoking
    `msiexec`, calls `AddPackageByUriAsync` to register the package
    for that user. The AppX deployment service rejects per-user adds
    from `LocalSystem` (`0x80073CF9` / "Local System account is not
    allowed to perform this operation"), so this CA must NOT use
    `Impersonate="no"`.
  - `ProvisionSparsePackage` — runs as `LocalSystem`, calls
    `ProvisionPackageForAllUsersAsync` so future logons inherit the
    package. Requires the package to already be staged, which
    `AddSparsePackage` takes care of, so it must be sequenced after.
  - `DeprovisionSparsePackage` — runs as `LocalSystem` on uninstall,
    the inverse of `ProvisionSparsePackage`.

  All three CAs never fail the MSI: `register-sparse.exe` exits 0 on
  legacy Windows where MSIX provisioning isn't available, and the
  runtime SDDL builder in `ipc/windows.rs` falls back to the legacy
  `BU` ACE via `GetCurrentPackageFullName -> APPMODEL_ERROR_NO_PACKAGE`.

  `register-sparse.exe` derives INSTALLDIR from its own
  `current_exe().parent()` rather than reading the MSI
  `CustomActionData` property: MSI only exposes that property to
  DLL/script-based deferred CAs, not to direct EXE CAs.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="SparsePackageMsix" Guid="34cca6d3-7b27-4d5e-b86b-3a3b4ee4dbe6">
        <File Id="FirezoneMsix" Name="firezone.msix"
              Source="../../firezone.msix" KeyPath="yes" />
      </Component>

      <Component Id="RegisterSparseExe" Guid="92c9f54d-1ab8-4b30-93bf-94c8c0d58f0c">
        <File Id="RegisterSparseExeFile" Name="register-sparse.exe"
              Source="../../register-sparse.exe" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <CustomAction Id="AddSparsePackage"
                  FileKey="RegisterSparseExeFile"
                  ExeCommand="add"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <CustomAction Id="ProvisionSparsePackage"
                  FileKey="RegisterSparseExeFile"
                  ExeCommand="provision"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="DeprovisionSparsePackage"
                  FileKey="RegisterSparseExeFile"
                  ExeCommand="deprovision"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!--
        `Add` must run impersonated (rejected for `LocalSystem`),
        `Provision` must run elevated and after `Add` (package must
        already be staged). Both must run before `StartServices` so
        the tunnel service is launched with the package SID already
        attached.
      -->
      <Custom Action="AddSparsePackage"
              Before="ProvisionSparsePackage">NOT REMOVE</Custom>
      <Custom Action="ProvisionSparsePackage"
              Before="StartServices">NOT REMOVE</Custom>

      <Custom Action="DeprovisionSparsePackage"
              Before="RemoveFiles">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>
  </Fragment>
</Wix>
