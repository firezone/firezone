<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX fragment for the Firezone sparse MSIX package. Pulled into the
  main MSI via `tauri.conf.json:fragmentPaths`. Ships the sparse-MSIX
  payload and the `register-sparse.exe` custom-action helper into
  INSTALLDIR, then fires two deferred CAs against it. See the
  `register-sparse.rs` module doc for what each subcommand does to the
  AppX deployment service; this fragment only deals with the MSI side.

  `Return="check"` makes a non-zero exit from `register-sparse` fail
  the install transaction. The `LaunchCondition` below guarantees we
  only ever reach the CA on a Windows build that actually supports
  external-location sparse-MSIX packages (Win10 21H2 / build 19044).
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!--
      Reads `HKLM\ŌĆ”\CurrentVersion\CurrentMajorVersionNumber`
      (REG_DWORD, added in Win10 and reports `10` on both Win10 and
      Win11) and `CurrentBuild` (REG_SZ, the kernel build number).
      `Type="raw"` keeps the DWORD's `#` prefix so the comparison
      below is unambiguous. Lexicographic compare on 5-digit Win10/11
      build numbers (all >= 10240) is equivalent to numeric.
    -->
    <Property Id="WIN_MAJOR_RAW" Secure="yes">
      <RegistrySearch Id="WinMajorVer"
                      Root="HKLM"
                      Key="SOFTWARE\Microsoft\Windows NT\CurrentVersion"
                      Name="CurrentMajorVersionNumber"
                      Type="raw" />
    </Property>
    <Property Id="WIN_BUILD" Secure="yes">
      <RegistrySearch Id="WinBuildNum"
                      Root="HKLM"
                      Key="SOFTWARE\Microsoft\Windows NT\CurrentVersion"
                      Name="CurrentBuild"
                      Type="raw" />
    </Property>

    <!--
      Refuse install on anything older than Win10 21H2. The MSIX
      sparse-package subsystem (`AddPackageByUriAsync` with
      `ExternalLocationUri`) ships there; on earlier builds
      registration silently no-ops and the tunnel pipe DACL grants
      access to a SID no process carries, making the app
      unreachable. The `Installed` clause lets uninstall still work
      even if the OS was somehow downgraded.
    -->
    <Condition Message="Firezone requires Windows 10 version 21H2 (build 19044) or later, or Windows 11.">
      <![CDATA[Installed OR (WIN_MAJOR_RAW = "#10" AND WIN_BUILD >= "19044")]]>
    </Condition>

    <DirectoryRef Id="INSTALLDIR">
      <Component Id="SparsePackageMsix" Guid="34cca6d3-7b27-4d5e-b86b-3a3b4ee4dbe6">
        <File Id="FirezoneMsix" Name="firezone.msix"
              Source="../../firezone.msix" KeyPath="yes" />
      </Component>

      <Component Id="RegisterSparseExe" Guid="92c9f54d-1ab8-4b30-93bf-94c8c0d58f0c">
        <File Id="RegisterSparseExeFile" Name="register-sparse.exe"
              Source="../../register-sparse.exe" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <CustomAction Id="ProvisionSparsePackage"
                  FileKey="RegisterSparseExeFile"
                  ExeCommand="provision"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="DeprovisionSparsePackage"
                  FileKey="RegisterSparseExeFile"
                  ExeCommand="deprovision"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <InstallExecuteSequence>
      <!--
        Provision must complete before `StartServices` so the tunnel
        service is launched with the package SID already attached.
      -->
      <Custom Action="ProvisionSparsePackage"
              Before="StartServices">NOT REMOVE</Custom>

      <Custom Action="DeprovisionSparsePackage"
              Before="RemoveFiles">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>
  </Fragment>
</Wix>
