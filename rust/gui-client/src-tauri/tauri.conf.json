{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "shortDescription": "Firezone",
    "targets": ["msi"],
    "windows": {
      "wix": {
        "bannerPath": "./win_files/banner.png",
        "componentRefs": [
          "RemoveOldFirezoneService",
          "FirezoneClientTunnelService",
          "SparsePackageMsix",
          "RegisterSparseExe"
        ],
        "dialogImagePath": "./win_files/install_dialog.png",
        "fragmentPaths": [
          "./win_files/service.wxs",
          "./win_files/sparse-package.wxs"
        ],
        "template": "./win_files/main.wxs"
      }
    },
    "icon": [
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "Firezone"
  },
  "mainBinaryName": "firezone-client-gui",
  "identifier": "dev.firezone.client",
  "plugins": {},
  "productName": "firezone-client-gui",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://sentry.firezone.dev; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; worker-src 'none'; manifest-src 'none'",
      "capabilities": ["default-capability"]
    },
    "windows": [
      {
        "decorations": false,
        "label": "main",
        "title": "Firezone",
        "url": "index.html",
        "fullscreen": false,
        "resizable": false,
        "width": 900,
        "height": 500,
        "visible": false,
        "transparent": true
      }
    ]
  }
}
